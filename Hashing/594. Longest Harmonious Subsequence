class Solution {
    public int findLHS(int[] nums) {
        Map<Integer, Integer> map = new HashMap<>();

        for(int i : nums){
            map.put(i, map.getOrDefault(i, 0)+1);
        }
        int res = 0;

        for(int c : map.keySet()){
            if(map.containsKey(c+1)){
                int curr = map.get(c);
                int next = map.get(c+1);

                res = Math.max(res, curr+next);

            }
        }
        return res;

        
        
    }
}
